{
	"name": "pict-provider-theme-playground",
	"version": "0.0.1",
	"description": "Interactive theme builder/playground for pict-provider-theme. Live-edit tokens + CSS, upload imagery, see a representative component gallery reflow instantly, export a compiled JSON bundle.",
	"main": "src/Pict-Application-Playground.js",
	"private": true,
	"retold": {
		"ExampleApplication": {
			"Stage": true,
			"Title": "Theme Playground",
			"Summary": "Interactive theme builder — live-edit tokens and CSS, upload imagery, watch a representative pict-section component gallery reflow instantly, and export a compiled JSON bundle.",
			"Complexity": "Advanced"
		}
	},
	"scripts": {
		"build": "npx quack build && npx quack copy",
		"serve": "node serve.js",
		"start": "npm run build && npm run serve"
	},
	"dependencies": {
		"@recogito/annotorious-openseadragon": "^2.7.19",
		"codejar": "^4.3.0",
		"fable": "^3.1.72",
		"openseadragon": "^6.0.2",
		"pict": "^1.0.367",
		"pict-application": "^1.0.34",
		"pict-provider-theme": "^1.1.2",
		"pict-router": "^1.0.10",
		"pict-section-code": "^1.0.6",
		"pict-section-content": "^0.1.7",
		"pict-section-entitymanagement": "^1.0.2",
		"pict-section-equation": "^0.0.3",
		"pict-section-filebrowser": "^0.0.3",
		"pict-section-flow": "^0.0.18",
		"pict-section-form": "^1.0.196",
		"pict-section-formeditor": "^1.0.13",
		"pict-section-histogram": "^1.0.0",
		"pict-section-inlinedocumentation": "^0.0.5",
		"pict-section-login": "^0.0.1",
		"pict-section-markdowneditor": "^1.0.11",
		"pict-section-modal": "^1.0.0",
		"pict-section-objecteditor": "^1.0.1",
		"pict-section-openseadragon": "^1.0.20",
		"pict-section-recordset": "^1.0.67",
		"pict-section-theme": "^1.1.1",
		"pict-section-tuigrid": "^1.0.31",
		"pict-section-usermanagement": "^0.0.1",
		"tui-grid": "^4.21.22"
	},
	"devDependencies": {
		"http-server": "^14.1.1",
		"quackage": "^1.2.3"
	},
	"copyFilesSettings": {
		"whenFileExists": "overwrite"
	},
	"copyFiles": [
		{
			"from": "./src/index.html",
			"to": "./dist/"
		},
		{
			"from": "./src/playground.css",
			"to": "./dist/"
		},
		{
			"from": "./src/themes/*.json",
			"to": "./dist/themes/"
		},
		{
			"from": "./node_modules/openseadragon/build/openseadragon/openseadragon.min.js",
			"to": "./dist/vendor/openseadragon/"
		},
		{
			"from": "./node_modules/openseadragon/build/openseadragon/images/*.png",
			"to": "./dist/vendor/openseadragon/images/"
		},
		{
			"from": "./node_modules/tui-grid/dist/tui-grid.min.js",
			"to": "./dist/vendor/tui-grid/"
		},
		{
			"from": "./node_modules/tui-grid/dist/tui-grid.min.css",
			"to": "./dist/vendor/tui-grid/"
		},
		{
			"from": "./node_modules/@recogito/annotorious-openseadragon/dist/openseadragon-annotorious.min.js",
			"to": "./dist/vendor/annotorious/"
		},
		{
			"from": "./node_modules/@recogito/annotorious-openseadragon/dist/annotorious.min.css",
			"to": "./dist/vendor/annotorious/"
		},
		{
			"from": "./src/vendor/codejar.js",
			"to": "./dist/vendor/codejar/"
		},
		{
			"from": "./src/vendor/codemirror-bundle.js",
			"to": "./dist/vendor/codemirror/"
		},
		{
			"from": "./node_modules/pict/dist/pict.min.js",
			"to": "./dist/vendor/pict/"
		}
	]
}
